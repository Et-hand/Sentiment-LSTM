   "source": [
    "Set Negative as 0 and Positive as 1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "412b3746",
   "metadata": {},
   "outputs": [],
   "source": [
    "label_map = {'NEGATIVE': 0, 'POSITIVE': 1}\n",
